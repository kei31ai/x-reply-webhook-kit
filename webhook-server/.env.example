# X webhook CRC / signature verification
X_CONSUMER_SECRET=your_x_api_secret_key

# X API access for webhook lookup and account subscription
X_BEARER_TOKEN=your_x_bearer_token
X_API_KEY=your_x_api_key
X_API_SECRET=your_x_api_secret_key
X_ACCESS_TOKEN=your_x_access_token
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret

# Local worker authentication
WORKER_TOKEN=replace_with_long_random_token

# Lease time in seconds after GET /pull
LEASE_SECONDS=300
